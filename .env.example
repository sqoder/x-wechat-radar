# ====== 必填（无翻译测试） ======
# 1) 从 x.com 登录后的 Cookie 里复制 auth_token 值
#    可填多个，用逗号分隔（提高稳定性）
TWITTER_AUTH_TOKEN=

# 2) 企业微信机器人 / 企业微信应用 webhook
#    个人微信推送建议配合 WEWORK_MSG_TYPE=text
WEWORK_WEBHOOK_URL=

# 2.1) 飞书机器人 webhook（推荐二选一配置：飞书 或 企业微信）
FEISHU_WEBHOOK_URL=

# 2.2) 分组优先推送 webhook（可选）
# 留空时，up-groups.sh 会自动回退到上面的全局 webhook
WEWORK_WEBHOOK_URL_AI=
WEWORK_WEBHOOK_URL_POLITICS=
WEWORK_WEBHOOK_URL_INVEST=
FEISHU_WEBHOOK_URL_AI=
FEISHU_WEBHOOK_URL_POLITICS=
FEISHU_WEBHOOK_URL_INVEST=

# 3) AI 翻译模型 API Key（可选：仅在开启翻译/AI分析时需要）
AI_API_KEY=
# 你当前默认配置已开启 ai_translation，因此这里建议必填

# ====== 建议值（可直接用） ======
TZ=Asia/Shanghai
WEWORK_MSG_TYPE=text
AI_MODEL=deepseek/deepseek-chat
CRON_SCHEDULE=*/5 * * * *
IMMEDIATE_RUN=true
AI_ANALYSIS_ENABLED=false
ENABLE_WEBSERVER=false
WEBSERVER_PORT=8080
RSSHUB_PORT=1200
IMMEDIATE_RUN_GROUPS=false
CRON_SCHEDULE_AI=1/5 * * * *
CRON_SCHEDULE_POLITICS=2/5 * * * *
CRON_SCHEDULE_INVEST=3/5 * * * *

# ====== 可选 ======
# 兼容 OpenAI 协议的代理地址/网关，比如 https://api.openai.com/v1
AI_API_BASE=

# 如你有可用的第三方 Twitter GraphQL 网关，可填此项替代 TWITTER_AUTH_TOKEN
TWITTER_THIRD_PARTY_API=
