# ====== 必填（当前配置默认开启翻译） ======
# 1) 从 x.com 登录后的 Cookie 里复制 auth_token 值
#    可填多个，用逗号分隔（提高稳定性）
TWITTER_AUTH_TOKEN=

# 2) 企业微信机器人 / 企业微信应用 webhook
#    个人微信推送建议配合 WEWORK_MSG_TYPE=text
WEWORK_WEBHOOK_URL=

# 2.1) 飞书机器人 webhook（推荐二选一配置：飞书 或 企业微信）
FEISHU_WEBHOOK_URL=
# 若飞书机器人开启了“签名校验”，这里填签名密钥（未开启可留空）
FEISHU_WEBHOOK_SECRET=

# 飞书“指令机器人（长连接）”配置（可选，支持在飞书里发命令查询）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_RSS_BASE=http://127.0.0.1:1200
FEISHU_BOT_ENABLE_TRANSLATE=true

# 2.2) 分组优先推送 webhook（可选）
# 留空时，up-groups.sh 会自动回退到上面的全局 webhook
WEWORK_WEBHOOK_URL_AI=
WEWORK_WEBHOOK_URL_POLITICS=
WEWORK_WEBHOOK_URL_INVEST=
FEISHU_WEBHOOK_URL_AI=
FEISHU_WEBHOOK_URL_POLITICS=
FEISHU_WEBHOOK_URL_INVEST=

# 3) AI API Key（翻译开启时必填）
AI_API_KEY=

# 4) 云端多模态媒体总结（图片/视频，可选）
#    开启后会对带图片/视频的帖子调用云模型做中文总结（会产生 API 费用）
AI_MEDIA_SUMMARY_ENABLED=false
AI_MEDIA_SUMMARY_PROVIDER=gemini
AI_MEDIA_SUMMARY_API_KEY=
AI_MEDIA_SUMMARY_MODEL=gemini-2.5-flash
AI_MEDIA_SUMMARY_TIMEOUT=45
AI_MEDIA_SUMMARY_MAX_ITEMS=3
AI_MEDIA_SUMMARY_MAX_DOWNLOAD_MB=20
AI_MEDIA_SUMMARY_CACHE_MAX_ENTRIES=10000

# ====== 建议值（可直接用） ======
TZ=Asia/Shanghai
WEWORK_MSG_TYPE=text
AI_MODEL=deepseek/deepseek-chat
CRON_SCHEDULE=*/5 * * * *
IMMEDIATE_RUN=true
AI_ANALYSIS_ENABLED=false
ENABLE_WEBSERVER=false
WEBSERVER_PORT=8080
RSSHUB_PORT=1200
IMMEDIATE_RUN_GROUPS=false
CRON_SCHEDULE_AI=1/5 * * * *
CRON_SCHEDULE_POLITICS=2/5 * * * *
CRON_SCHEDULE_INVEST=3/5 * * * *

# 稳定模式（分片抓取）建议值
# 启动方式：./scripts/up-stable.sh
SHARD_CRON_SCHEDULE_1=0-59/5 * * * *
SHARD_CRON_SCHEDULE_2=1-59/5 * * * *
SHARD_CRON_SCHEDULE_3=2-59/5 * * * *
IMMEDIATE_RUN_SHARDS=false

# 飞书指令机器人日志轮转
FEISHU_BOT_LOG_MAX_BYTES=5242880
FEISHU_BOT_LOG_BACKUPS=5

# ====== 可选 ======
# 兼容 OpenAI 协议的代理地址/网关（默认留空）
AI_API_BASE=

# 本地开源翻译模型示例（按需启用）：
# AI_API_KEY=local_dummy_key
# AI_API_BASE=http://host.docker.internal:11434/v1
# AI_MODEL=openai/qwen2.5:1.5b

# 如你有可用的第三方 Twitter GraphQL 网关，可填此项替代 TWITTER_AUTH_TOKEN
TWITTER_THIRD_PARTY_API=
